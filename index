                <div class="toggle-container"><label class="toggle-switch"><input type="checkbox" id="grid-toggle" checked><span class="toggle-slider"></span></label><span>Gitternetz</span></div>
                <div class="toggle-container"><label class="toggle-switch"><input type="checkbox" id="rapid-toggle" checked><span class="toggle-slider"></span></label><span>Schnellbewegungen (rot)</span></div>
                <div class="toggle-container"><label class="toggle-switch"><input type="checkbox" id="depth-toggle"><span class="toggle-slider"></span></label><span>Tiefeneffekt (3D)</span></div>

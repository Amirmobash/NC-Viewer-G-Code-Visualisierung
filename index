<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no">
    <title>NC-Viewer Premium | CNC G-Code Visualisierung</title>
    <meta name="description" content="Professioneller G-Code Viewer mit moderner Benutzeroberfläche. 2D/3D Visualisierung, Simulation und Analyse für die Fertigungsindustrie.">
    <meta name="theme-color" content="#f97316">
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: #fffbf5;
            color: #1e293b;
            line-height: 1.5;
            overflow-x: hidden;
        }

        /* Premium Orange & White Theme */
        :root {
            --orange-50: #fff7ed;
            --orange-100: #ffedd5;
            --orange-200: #fed7aa;
            --orange-500: #f97316;
            --orange-600: #ea580c;
            --orange-700: #c2410c;
            --gray-50: #fafaf9;
            --gray-100: #f5f5f4;
            --gray-200: #e7e5e4;
            --gray-300: #d6d3d1;
            --gray-600: #57534e;
            --gray-800: #292524;
            --white: #ffffff;
            --shadow-sm: 0 1px 2px 0 rgba(0,0,0,0.03);
            --shadow-md: 0 8px 20px -6px rgba(0,0,0,0.08), 0 2px 4px -2px rgba(0,0,0,0.02);
            --shadow-lg: 0 20px 25px -12px rgba(0,0,0,0.1);
            --radius-2xl: 1.5rem;
            --radius-xl: 1rem;
            --radius-lg: 0.75rem;
        }

        /* Glas / moderne Effekte */
        .glass-card {
            background: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(2px);
            border: 1px solid rgba(249, 115, 22, 0.15);
        }

        header {
            background: var(--white);
            border-bottom: 2px solid var(--orange-200);
            box-shadow: var(--shadow-sm);
            position: sticky;
            top: 0;
            z-index: 20;
        }

        .header-content {
            max-width: 1440px;
            margin: 0 auto;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .logo-icon {
            font-size: 2rem;
            background: linear-gradient(135deg, var(--orange-500), var(--orange-700));
            -webkit-background-clip: text;
            background-clip: text;
            color: transparent;
        }

        h1 {
            font-size: 1.7rem;
            font-weight: 700;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #1e293b, #f97316);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent;
        }

        .badge {
            background: var(--orange-50);
            padding: 0.25rem 0.9rem;
            border-radius: 2rem;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--orange-600);
            border: 1px solid var(--orange-200);
        }

        .container {
            max-width: 1440px;
            margin: 1.8rem auto;
            padding: 0 1.8rem;
        }

        /* 2 Spalten Grid */
        .dashboard {
            display: grid;
            grid-template-columns: 330px 1fr;
            gap: 1.8rem;
        }

        /* Control Panel modern */
        .control-panel {
            background: var(--white);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-md);
            padding: 1.6rem;
            border: 1px solid var(--orange-100);
            transition: transform 0.2s ease;
        }

        .section-title {
            font-size: 1rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            color: var(--gray-800);
            border-left: 3px solid var(--orange-500);
            padding-left: 0.75rem;
        }

        .upload-zone {
            background: var(--orange-50);
            border: 2px dashed var(--orange-200);
            border-radius: var(--radius-xl);
            padding: 1.5rem 1rem;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s ease;
            margin-bottom: 1rem;
        }

        .upload-zone:hover {
            border-color: var(--orange-500);
            background: #fff5e8;
            transform: scale(0.98);
        }

        .btn {
            border: none;
            border-radius: 2rem;
            padding: 0.6rem 1.2rem;
            font-weight: 500;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.2s cubic-bezier(0.2, 0.9, 0.4, 1.1);
            display: inline-flex;
            align-items: center;
            gap: 8px;
            justify-content: center;
        }

        .btn-primary {
            background: var(--orange-500);
            color: white;
            box-shadow: 0 2px 6px rgba(249,115,22,0.3);
        }

        .btn-primary:hover {
            background: var(--orange-600);
            transform: translateY(-2px);
            box-shadow: 0 8px 18px rgba(249,115,22,0.25);
        }

        .btn-secondary {
            background: var(--gray-100);
            color: var(--gray-800);
            border: 1px solid var(--gray-200);
        }

        .btn-secondary:hover {
            background: var(--gray-200);
            transform: translateY(-1px);
        }

        .btn-outline-orange {
            background: transparent;
            border: 1.5px solid var(--orange-500);
            color: var(--orange-600);
        }

        .btn-outline-orange:hover {
            background: var(--orange-500);
            color: white;
        }

        .slider-group {
            margin: 1.2rem 0;
        }

        .slider-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.8rem;
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        input[type="range"] {
            width: 100%;
            height: 5px;
            border-radius: 10px;
            background: var(--gray-200);
            -webkit-appearance: none;
        }

        input[type="range"]:focus {
            outline: none;
        }

        input[type="range"]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 18px;
            height: 18px;
            background: var(--orange-500);
            border-radius: 50%;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
            border: 2px solid white;
        }

        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 0.9rem 0;
        }

        .toggle-switch {
            position: relative;
            display: inline-block;
            width: 46px;
            height: 24px;
        }

        .toggle-switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .toggle-slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #ccc;
            transition: 0.3s;
            border-radius: 34px;
        }

        .toggle-slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: 0.3s;
            border-radius: 50%;
        }

        input:checked + .toggle-slider {
            background-color: var(--orange-500);
        }

        input:checked + .toggle-slider:before {
            transform: translateX(22px);
        }

        .info-card {
            background: var(--gray-50);
            border-radius: var(--radius-lg);
            padding: 1rem;
            font-size: 0.8rem;
            margin: 1rem 0;
        }

        .info-row {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.6rem;
        }

        .gcode-preview {
            background: #1e1b18;
            color: #fde68a;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.7rem;
            border-radius: var(--radius-lg);
            padding: 0.8rem;
            max-height: 180px;
            overflow-y: auto;
        }

        /* Visualization Area */
        .viz-card {
            background: var(--white);
            border-radius: var(--radius-2xl);
            box-shadow: var(--shadow-md);
            border: 1px solid var(--orange-100);
            overflow: hidden;
            transition: all 0.2s;
        }

        .viz-header {
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid var(--gray-100);
            background: rgba(255,251,245,0.6);
        }

        .view-tabs {
            display: flex;
            background: var(--gray-100);
            border-radius: 2rem;
            padding: 0.2rem;
        }

        .view-tab {
            padding: 0.4rem 1.2rem;
            border: none;
            background: transparent;
            border-radius: 2rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.2s;
        }

        .view-tab.active {
            background: var(--orange-500);
            color: white;
            box-shadow: var(--shadow-sm);
        }

        .canvas-wrapper {
            position: relative;
            background: #fefaf5;
            aspect-ratio: 16 / 10;
            cursor: grab;
        }

        .canvas-wrapper:active {
            cursor: grabbing;
        }

        canvas {
            width: 100%;
            height: 100%;
            display: block;
        }

        .overlay-status {
            position: absolute;
            bottom: 12px;
            left: 12px;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(6px);
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            font-weight: 500;
            color: white;
            font-family: monospace;
            pointer-events: none;
        }

        .overlay-coord {
            position: absolute;
            bottom: 12px;
            right: 12px;
            background: rgba(0,0,0,0.65);
            backdrop-filter: blur(6px);
            padding: 4px 12px;
            border-radius: 40px;
            font-size: 0.7rem;
            color: white;
            font-family: monospace;
        }

        .action-bar {
            padding: 1rem 1.5rem;
            display: flex;
            justify-content: space-between;
            gap: 0.8rem;
            flex-wrap: wrap;
            background: white;
            border-top: 1px solid var(--gray-100);
        }

        @media (max-width: 900px) {
            .dashboard {
                grid-template-columns: 1fr;
            }
            .container {
                padding: 0 1rem;
            }
        }

        footer {
            text-align: center;
            padding: 2rem;
            margin-top: 2rem;
            color: var(--gray-600);
            font-size: 0.8rem;
            border-top: 1px solid var(--gray-200);
        }
    </style>
</head>
<body>
<header>
    <div class="header-content">
        <div class="logo">
            <div class="logo-icon">⚡🧡</div>
            <div>
                <h1>NC-Viewer <span style="color:#f97316;">Premium</span></h1>
                <div class="badge">G-Code Visualisierung · 2D/3D · Simulation</div>
            </div>
        </div>
        <a href="https://www.nivt.de/" class="btn btn-outline-orange" style="text-decoration:none;">🌐 nivt.de</a>
    </div>
</header>

<div class="container">
    <div class="dashboard">
        <!-- Linke Steuerung -->
        <div class="control-panel">
            <div class="section-title">📁 Datei laden</div>
            <div class="upload-zone" id="uploadZone">
                <div style="font-size:2rem;">📂</div>
                <p style="font-weight:500;">Datei ablegen oder klicken</p>
                <p style="font-size:0.7rem; color:gray;">.nc · .gcode · .cnc · .txt</p>
                <input type="file" id="fileInput" accept=".nc,.gcode,.cnc,.txt" style="display:none">
            </div>
            <button class="btn btn-secondary" id="sampleBtn" style="width:100%; margin-bottom:1.5rem;">📋 Beispiel G-Code laden</button>

            <div class="section-title">🎨 Anzeige</div>
            <div class="toggle-row"><span>📐 Gitternetz</span><label class="toggle-switch"><input type="checkbox" id="gridToggle" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-row"><span>⚡ Schnellbewegungen (orange)</span><label class="toggle-switch"><input type="checkbox" id="rapidToggle" checked><span class="toggle-slider"></span></label></div>
            <div class="toggle-row"><span>🌀 Tiefeneffekt (3D)</span><label class="toggle-switch"><input type="checkbox" id="depthToggle"><span class="toggle-slider"></span></label></div>

            <div class="slider-group"><div class="slider-label"><span>📏 Linienstärke</span><span id="lineWidthValue">Mittel</span></div><input type="range" id="lineWidthSlider" min="1" max="3" value="2" step="1"></div>
            <div class="slider-group"><div class="slider-label"><span>🎬 Animationsgeschw.</span><span id="speedValue">Mittel</span></div><input type="range" id="speedSlider" min="1" max="4" value="2" step="1"></div>

            <div style="display: flex; gap: 8px; margin: 1rem 0;">
                <button class="btn btn-secondary" id="fitViewBtn">🔍 Zentrieren</button>
                <button class="btn btn-secondary" id="resetViewBtn">🔄 Reset</button>
            </div>

            <div class="section-title">📊 Datei-Info</div>
            <div class="info-card">
                <div class="info-row"><span>📄 Dateiname:</span><span id="fileName">—</span></div>
                <div class="info-row"><span>📦 Größe:</span><span id="fileSize">—</span></div>
                <div class="info-row"><span>📝 Zeilen:</span><span id="lineCount">—</span></div>
                <div class="info-row"><span>📐 X-Bereich:</span><span id="rangeX">—</span></div>
                <div class="info-row"><span>📐 Y/Z-Bereich:</span><span id="rangeYZ">—</span></div>
                <div class="info-row"><span>📏 Einheiten:</span><span id="unitsInfo">mm</span></div>
            </div>

            <div class="section-title">📜 G-Code Vorschau</div>
            <div class="gcode-preview" id="gcodePreview"><span style="color:#aaa;">Keine Datei geladen</span></div>
        </div>

        <!-- Rechte Visualisierung -->
        <div class="viz-card">
            <div class="viz-header">
                <h3 style="font-weight:600; font-size:1.1rem;" id="viewTitle">2D Draufsicht</h3>
                <div class="view-tabs">
                    <button class="view-tab active" data-view="2d">2D</button>
                    <button class="view-tab" data-view="3d">3D Orbit</button>
                </div>
            </div>
            <div class="canvas-wrapper" id="canvasWrapper">
                <canvas id="viewerCanvas"></canvas>
                <div class="overlay-status">🔍 Zoom: <span id="zoomLevel">100%</span> | 📐 <span id="viewModeLabel">2D</span></div>
                <div class="overlay-coord" id="coordDisplay">📍 X:0.00 Y:0.00 Z:0.00</div>
            </div>
            <div class="action-bar">
                <div style="display:flex; gap:8px;">
                    <button class="btn btn-primary" id="playSimBtn">▶️ Simulation starten</button>
                    <button class="btn btn-secondary" id="stepSimBtn">⏭️ Schritt</button>
                    <button class="btn btn-secondary" id="resetSimBtn">🔄 Reset Sim</button>
                </div>
                <button class="btn btn-outline-orange" id="exportImgBtn">📸 Als PNG exportieren</button>
            </div>
            <div style="font-size:0.65rem; text-align:center; padding:0.5rem; color:gray; background:#fefaf5;">🖱️ Maus: Ziehen = Pan (2D) / Rotation (3D) | Shift+ziehen = Pan (3D) | Scroll = Zoom</div>
        </div>
    </div>
</div>
<footer>
    <p>NC-Viewer Premium – Hochpräzise CNC-Programm Visualisierung | Weiß-Orange Edition</p>
    <p style="margin-top:0.3rem;">Unterstützt G-Code (G0, G1, G2, G3) · Echtzeit-Simulation</p>
</footer>

<script>
    (function() {
        // ---------- ERWEITERTER G-CODE VIEWER MIT PREMIUM UI ----------
        class PremiumGCodeViewer {
            constructor(canvas) {
                this.canvas = canvas;
                this.ctx = canvas.getContext('2d');
                this.segments = [];
                this.bbox = { minX:0, minY:0, minZ:0, maxX:0, maxY:0, maxZ:0 };
                this.view2D = { zoom:1.2, panX:0, panY:0, offsetX:0, offsetY:0 };
                this.view3D = { yaw: -30, pitch: 35, distance: 200, targetX:0, targetY:0, targetZ:0 };
                this.mode = { absolute: true, units: 'mm' };
                this.currentPos = { x:0, y:0, z:0 };
                this.playIndex = 0;
                this.isPlaying = false;
                this.interval = null;
                this.speedMap = [800, 300, 120, 45];
                this.lineWidthMap = [1.2, 2.2, 3.6];
                this.activeView = '2d';
                this.initResize();
                this.attachMouse();
            }

            initResize() {
                const resizeObserver = new ResizeObserver(() => this.handleResize());
                resizeObserver.observe(this.canvas.parentElement);
                this.handleResize();
            }

            handleResize() {
                const container = this.canvas.parentElement;
                const rect = container.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                this.canvas.style.width = rect.width + 'px';
                this.canvas.style.height = rect.height + 'px';
                this.canvas.width = Math.max(1, rect.width * dpr);
                this.canvas.height = Math.max(1, rect.height * dpr);
                this.ctx.setTransform(1,0,0,1,0,0);
                this.ctx.scale(dpr, dpr);
                const cssW = this.canvas.width / dpr;
                const cssH = this.canvas.height / dpr;
                if (this.view2D.offsetX === 0) this.view2D.offsetX = cssW/2;
                if (this.view2D.offsetY === 0) this.view2D.offsetY = cssH/2;
                this.draw();
            }

            attachMouse() {
                const wrap = this.canvas.parentElement;
                let isPan2D = false, isRot3D = false, isPan3D = false, lastX=0, lastY=0;
                wrap.addEventListener('wheel', (e) => {
                    e.preventDefault();
                    if(this.activeView === '2d') {
                        let factor = e.deltaY > 0 ? 0.92 : 1.08;
                        this.view2D.zoom = Math.min(12, Math.max(0.2, this.view2D.zoom * factor));
                    } else {
                        let factor = e.deltaY > 0 ? 1.05 : 0.95;
                        this.view3D.distance = Math.min(800, Math.max(30, this.view3D.distance * factor));
                    }
                    this.updateUI(); this.draw();
                });
                wrap.addEventListener('mousedown', (e) => {
                    if(e.button !== 0) return;
                    if(this.activeView === '2d') isPan2D = true;
                    else { if(e.shiftKey) isPan3D = true; else isRot3D = true; }
                    lastX = e.clientX; lastY = e.clientY;
                    wrap.style.cursor = 'grabbing';
                });
                window.addEventListener('mousemove', (e) => {
                    if(isPan2D) {
                        let dx = e.clientX - lastX, dy = e.clientY - lastY;
                        this.view2D.panX -= dx / this.view2D.zoom;
                        this.view2D.panY -= dy / this.view2D.zoom;
                        lastX = e.clientX; lastY = e.clientY;
                        this.draw();
                    } else if(isRot3D) {
                        this.view3D.yaw += (e.clientX - lastX) * 0.7;
                        this.view3D.pitch += (e.clientY - lastY) * 0.7;
                        this.view3D.pitch = Math.min(89, Math.max(-89, this.view3D.pitch));
                        lastX = e.clientX; lastY = e.clientY;
                        this.updateUI(); this.draw();
                    } else if(isPan3D) {
                        let spd = this.view3D.distance * 0.002;
                        this.view3D.targetX -= (e.clientX - lastX) * spd;
                        this.view3D.targetY += (e.clientY - lastY) * spd;
                        lastX = e.clientX; lastY = e.clientY;
                        this.draw();
                    }
                });
                window.addEventListener('mouseup', () => { isPan2D=false; isRot3D=false; isPan3D=false; wrap.style.cursor = 'grab'; });
                wrap.addEventListener('mousemove', (e) => {
                    if(this.activeView === '2d') {
                        const rect = this.canvas.getBoundingClientRect();
                        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
                        const wx = this.screenToWorldX(mx), wy = this.screenToWorldY(my);
                        document.getElementById('coordDisplay').innerHTML = `📍 X:${wx.toFixed(2)} Y:${wy.toFixed(2)} Z:0.00`;
                    } else {
                        document.getElementById('coordDisplay').innerHTML = `🎯 3D · Ziel: X:${this.view3D.targetX.toFixed(1)} Y:${this.view3D.targetY.toFixed(1)} Z:${this.view3D.targetZ.toFixed(1)}`;
                    }
                });
            }

            screenToWorldX(sx) { return (sx - this.view2D.offsetX)/this.view2D.zoom + this.view2D.panX; }
            screenToWorldY(sy) { return (sy - this.view2D.offsetY)/this.view2D.zoom + this.view2D.panY; }
            worldToScreenX(wx) { return (wx - this.view2D.panX)*this.view2D.zoom + this.view2D.offsetX; }
            worldToScreenY(wy) { return (wy - this.view2D.panY)*this.view2D.zoom + this.view2D.offsetY; }

            project3D(x,y,z) {
                let rx = x - this.view3D.targetX, ry = y - this.view3D.targetY, rz = z - this.view3D.targetZ;
                const yawRad = this.view3D.yaw * Math.PI/180, pitchRad = this.view3D.pitch * Math.PI/180;
                const x1 = rx * Math.cos(yawRad) - rz * Math.sin(yawRad);
                const z1 = rx * Math.sin(yawRad) + rz * Math.cos(yawRad);
                const y1 = ry * Math.cos(pitchRad) - z1 * Math.sin(pitchRad);
                const z2 = ry * Math.sin(pitchRad) + z1 * Math.cos(pitchRad);
                const fov = Math.PI/4;
                const scale = Math.min(this.canvas.width/(window.devicePixelRatio||1), this.canvas.height/(window.devicePixelRatio||1))/2;
                const zTrans = z2 - this.view3D.distance;
                const factor = fov / (Math.abs(zTrans) < 0.001 ? 0.001 : zTrans);
                return { x: x1 * factor * scale + this.canvas.width/(window.devicePixelRatio||1)/2, y: y1 * factor * scale + this.canvas.height/(window.devicePixelRatio||1)/2, depth: zTrans };
            }

            parseGCode(code) {
                this.segments = [];
                this.currentPos = {x:0,y:0,z:0};
                this.mode = { absolute: true, units: 'mm' };
                const lines = code.split(/\r?\n/);
                for(let line of lines) {
                    let clean = line.split(';')[0].split('(')[0].trim().toUpperCase();
                    if(!clean) continue;
                    if(clean.includes('G90')) this.mode.absolute = true;
                    if(clean.includes('G91')) this.mode.absolute = false;
                    if(clean.includes('G20')) this.mode.units = 'inch';
                    if(clean.includes('G21')) this.mode.units = 'mm';
                    if(clean.match(/G0[0]?/)) this.move(clean, true);
                    else if(clean.match(/G1[01]?/)) this.move(clean, false);
                    else if(clean.match(/G2|G3|G02|G03/)) this.arc(clean);
                }
                this.calcBBox();
                this.fitToView();
                this.stopSim();
                this.playIndex = 0;
                this.updateUI();
                this.draw();
            }

            move(line, rapid) {
                let x = this.currentPos.x, y = this.currentPos.y, z = this.currentPos.z;
                const get = (c) => { let m = line.match(new RegExp(c+'([-+]?\\d*\\.?\\d+)')); return m ? parseFloat(m[1]) : null; };
                let nx = get('X'), ny = get('Y'), nz = get('Z');
                if(nx !== null) x = this.mode.absolute ? nx : this.currentPos.x + nx;
                if(ny !== null) y = this.mode.absolute ? ny : this.currentPos.y + ny;
                if(nz !== null) z = this.mode.absolute ? nz : this.currentPos.z + nz;
                if(this.mode.units === 'inch') { x*=25.4; y*=25.4; z*=25.4; }
                if((nx!==null || ny!==null || nz!==null) && (x!==this.currentPos.x || y!==this.currentPos.y || z!==this.currentPos.z)) {
                    this.segments.push({ x1:this.currentPos.x, y1:this.currentPos.y, z1:this.currentPos.z, x2:x, y2:y, z2:z, rapid });
                    this.currentPos = {x,y,z};
                }
            }

            arc(line) {
                let xm = line.match(/X([-+]?\d*\.?\d+)/), ym = line.match(/Y([-+]?\d*\.?\d+)/), im = line.match(/I([-+]?\d*\.?\d+)/), jm = line.match(/J([-+]?\d*\.?\d+)/);
                if(!xm || !ym || !im || !jm) return;
                let nx = parseFloat(xm[1]), ny = parseFloat(ym[1]), i = parseFloat(im[1]), j = parseFloat(jm[1]);
                if(!this.mode.absolute) { nx += this.currentPos.x; ny += this.currentPos.y; }
                const centerX = this.currentPos.x + i, centerY = this.currentPos.y + j;
                const radius = Math.hypot(this.currentPos.x - centerX, this.currentPos.y - centerY);
                let startAng = Math.atan2(this.currentPos.y - centerY, this.currentPos.x - centerX);
                let endAng = Math.atan2(ny - centerY, nx - centerX);
                const clockwise = line.includes('G2') || line.includes('G02');
                let angleDiff = endAng - startAng;
                if(clockwise) { while(angleDiff > 0) angleDiff -= 2*Math.PI; while(angleDiff < -2*Math.PI) angleDiff += 2*Math.PI; }
                else { while(angleDiff < 0) angleDiff += 2*Math.PI; while(angleDiff > 2*Math.PI) angleDiff -= 2*Math.PI; }
                const steps = Math.max(12, Math.floor(Math.abs(angleDiff) * 18 / (2*Math.PI)));
                let lastX = this.currentPos.x, lastY = this.currentPos.y;
                for(let s=1; s<=steps; s++) {
                    let ang = startAng + angleDiff * s/steps;
                    let px = centerX + radius * Math.cos(ang), py = centerY + radius * Math.sin(ang);
                    this.segments.push({ x1:lastX, y1:lastY, z1:this.currentPos.z, x2:px, y2:py, z2:this.currentPos.z, rapid:false, arc:true });
                    lastX = px; lastY = py;
                }
                this.currentPos = { x:nx, y:ny, z:this.currentPos.z };
            }

            calcBBox() {
                if(!this.segments.length) { this.bbox={minX:-20,minY:-20,minZ:-20,maxX:20,maxY:20,maxZ:20}; return; }
                let minX=Infinity,minY=Infinity,minZ=Infinity,maxX=-Infinity,maxY=-Infinity,maxZ=-Infinity;
                for(let s of this.segments) {
                    minX=Math.min(minX,s.x1,s.x2); maxX=Math.max(maxX,s.x1,s.x2);
                    minY=Math.min(minY,s.y1,s.y2); maxY=Math.max(maxY,s.y1,s.y2);
                    minZ=Math.min(minZ,s.z1,s.z2); maxZ=Math.max(maxZ,s.z1,s.z2);
                }
                let pad = Math.max((maxX-minX)*0.08, (maxY-minY)*0.08, 1);
                this.bbox = { minX:minX-pad, maxX:maxX+pad, minY:minY-pad, maxY:maxY+pad, minZ:minZ-pad, maxZ:maxZ+pad };
                document.getElementById('rangeX').innerText = `${minX.toFixed(1)}..${maxX.toFixed(1)}`;
                document.getElementById('rangeYZ').innerText = `Y:${minY.toFixed(1)}..${maxY.toFixed(1)} Z:${minZ.toFixed(1)}..${maxZ.toFixed(1)}`;
            }

            fitToView() {
                if(this.activeView === '2d') {
                    const w = this.canvas.width/(window.devicePixelRatio||1), h = this.canvas.height/(window.devicePixelRatio||1);
                    const ww = this.bbox.maxX-this.bbox.minX, hh = this.bbox.maxY-this.bbox.minY;
                    if(ww>0 && hh>0) {
                        this.view2D.zoom = Math.min(w/ww, h/hh) * 0.9;
                        this.view2D.panX = (this.bbox.minX+this.bbox.maxX)/2;
                        this.view2D.panY = (this.bbox.minY+this.bbox.maxY)/2;
                        this.view2D.offsetX = w/2; this.view2D.offsetY = h/2;
                    }
                } else {
                    this.view3D.targetX = (this.bbox.minX+this.bbox.maxX)/2;
                    this.view3D.targetY = (this.bbox.minY+this.bbox.maxY)/2;
                    this.view3D.targetZ = (this.bbox.minZ+this.bbox.maxZ)/2;
                    let maxDim = Math.max(this.bbox.maxX-this.bbox.minX, this.bbox.maxY-this.bbox.minY, this.bbox.maxZ-this.bbox.minZ);
                    this.view3D.distance = maxDim * 1.4;
                    this.view3D.yaw = -35; this.view3D.pitch = 30;
                }
                this.updateUI(); this.draw();
            }

            draw() {
                const w = this.canvas.width/(window.devicePixelRatio||1), h = this.canvas.height/(window.devicePixelRatio||1);
                this.ctx.clearRect(0,0,w,h);
                this.ctx.fillStyle = '#FFFFFF'; this.ctx.fillRect(0,0,w,h);
                if(this.activeView === '2d') this.draw2D(w,h);
                else this.draw3D(w,h);
            }

            draw2D(w,h) {
                if(document.getElementById('gridToggle').checked) this.drawGrid2D(w,h);
                const rapidVis = document.getElementById('rapidToggle').checked;
                const lw = this.lineWidthMap[parseInt(document.getElementById('lineWidthSlider').value)-1];
                for(let i=0; i<this.segments.length; i++) {
                    if(this.isPlaying && i>=this.playIndex) break;
                    let s=this.segments[i];
                    let x1=this.worldToScreenX(s.x1), y1=this.worldToScreenY(s.y1), x2=this.worldToScreenX(s.x2), y2=this.worldToScreenY(s.y2);
                    this.ctx.beginPath(); this.ctx.moveTo(x1,y1); this.ctx.lineTo(x2,y2);
                    if(s.rapid && rapidVis) { this.ctx.strokeStyle = '#f97316'; this.ctx.setLineDash([7,5]); }
                    else { this.ctx.strokeStyle = '#ea580c'; this.ctx.setLineDash([]); }
                    this.ctx.lineWidth = lw; this.ctx.stroke();
                }
                this.ctx.setLineDash([]);
                if(this.isPlaying && this.playIndex>0) {
                    let last = this.segments[this.playIndex-1];
                    let cx=this.worldToScreenX(last.x2), cy=this.worldToScreenY(last.y2);
                    this.ctx.fillStyle = '#f97316'; this.ctx.shadowBlur=0;
                    this.ctx.beginPath(); this.ctx.arc(cx,cy,6,0,2*Math.PI); this.ctx.fill();
                }
            }

            drawGrid2D(w,h) {
                let step=10; if(this.view2D.zoom>1.5) step=5;
                this.ctx.strokeStyle='#e9e5e0'; this.ctx.lineWidth=0.8;
                const left=this.screenToWorldX(0), right=this.screenToWorldX(w), top=this.screenToWorldY(0), bottom=this.screenToWorldY(h);
                for(let x=Math.floor(left/step)*step; x<=right; x+=step) { let sx=this.worldToScreenX(x); if(sx>0&&sx<w){ this.ctx.beginPath(); this.ctx.moveTo(sx,0); this.ctx.lineTo(sx,h); this.ctx.stroke(); } }
                for(let y=Math.floor(top/step)*step; y<=bottom; y+=step) { let sy=this.worldToScreenY(y); if(sy>0&&sy<h){ this.ctx.beginPath(); this.ctx.moveTo(0,sy); this.ctx.lineTo(w,sy); this.ctx.stroke(); } }
                let ax=this.worldToScreenX(0), ay=this.worldToScreenY(0);
                this.ctx.beginPath(); this.ctx.strokeStyle='#f97316'; this.ctx.lineWidth=1.5;
                if(ax>0&&ax<w){ this.ctx.moveTo(ax,0); this.ctx.lineTo(ax,h); } if(ay>0&&ay<h){ this.ctx.moveTo(0,ay); this.ctx.lineTo(w,ay); } this.ctx.stroke();
            }

            draw3D(w,h) {
                if(document.getElementById('gridToggle').checked) this.drawGrid3D();
                const rapidVis = document.getElementById('rapidToggle').checked, depthEff = document.getElementById('depthToggle').checked;
                const lw = this.lineWidthMap[parseInt(document.getElementById('lineWidthSlider').value)-1];
                let proj = [];
                for(let i=0; i<this.segments.length; i++) {
                    if(this.isPlaying && i>=this.playIndex) break;
                    let s=this.segments[i];
                    let p1=this.project3D(s.x1,s.y1,s.z1), p2=this.project3D(s.x2,s.y2,s.z2);
                    proj.push({p1,p2,rapid:s.rapid,depth:(p1.depth+p2.depth)/2});
                }
                proj.sort((a,b)=>b.depth-a.depth);
                for(let p of proj) {
                    this.ctx.beginPath(); this.ctx.moveTo(p.p1.x,p.p1.y); this.ctx.lineTo(p.p2.x,p.p2.y);
                    if(p.rapid && rapidVis) { this.ctx.strokeStyle = '#f97316'; this.ctx.setLineDash([6,6]); }
                    else { this.ctx.strokeStyle = '#ea580c'; this.ctx.setLineDash([]); }
                    if(depthEff) this.ctx.globalAlpha = Math.min(1, Math.max(0.3, 1 - (p.depth+this.view3D.distance)/(this.view3D.distance*1.5)));
                    else this.ctx.globalAlpha = 1;
                    this.ctx.lineWidth = lw; this.ctx.stroke();
                }
                this.ctx.globalAlpha=1; this.ctx.setLineDash([]);
            }

            drawGrid3D() {
                let size=60, step=10;
                this.ctx.strokeStyle='#ddd8d0'; this.ctx.lineWidth=0.8;
                for(let x=-size; x<=size; x+=step) { let p1=this.project3D(x,-size,0), p2=this.project3D(x,size,0); this.ctx.beginPath(); this.ctx.moveTo(p1.x,p1.y); this.ctx.lineTo(p2.x,p2.y); this.ctx.stroke(); }
                for(let y=-size; y<=size; y+=step) { let p1=this.project3D(-size,y,0), p2=this.project3D(size,y,0); this.ctx.beginPath(); this.ctx.moveTo(p1.x,p1.y); this.ctx.lineTo(p2.x,p2.y); this.ctx.stroke(); }
            }

            playSim() { if(!this.segments.length) return; if(this.isPlaying){ this.stopSim(); return; } this.isPlaying=true; this.playIndex=0; let idx=parseInt(document.getElementById('speedSlider').value)-1; let delay=this.speedMap[idx]; this.interval=setInterval(()=>{ if(this.playIndex<this.segments.length){ this.playIndex++; this.draw(); if(this.playIndex>=this.segments.length) this.stopSim(); } else this.stopSim(); }, delay); document.getElementById('playSimBtn').innerHTML='⏹️ Stoppen'; }
            stopSim() { if(this.interval) clearInterval(this.interval); this.isPlaying=false; this.interval=null; document.getElementById('playSimBtn').innerHTML='▶️ Simulation starten'; this.draw(); }
            stepSim() { if(!this.isPlaying && this.playIndex>=this.segments.length) this.playIndex=0; if(this.playIndex<this.segments.length){ this.playIndex++; this.draw(); if(this.playIndex>=this.segments.length) this.stopSim(); } }
            resetSim() { this.stopSim(); this.playIndex=0; this.draw(); }
            updateUI() { document.getElementById('zoomLevel').innerText=Math.round((this.activeView==='2d'?this.view2D.zoom:this.view3D.distance/100)*100)+'%'; document.getElementById('viewModeLabel').innerText=this.activeView; }
            setView(v) { this.activeView=v; document.querySelectorAll('.view-tab').forEach(t=>t.classList.toggle('active',t.dataset.view===v)); document.getElementById('viewTitle').innerText=v==='2d'?'2D Draufsicht':'3D Orbit-Ansicht'; this.fitToView(); this.updateUI(); this.draw(); }
            exportImage() { let link=document.createElement('a'); link.download='nc_viewer.png'; link.href=this.canvas.toDataURL(); link.click(); }
        }

        // DOM bindings
        const canvas = document.getElementById('viewerCanvas');
        const viewer = new PremiumGCodeViewer(canvas);
        const uploadZone = document.getElementById('uploadZone'), fileInput = document.getElementById('fileInput');
        const sampleBtn = document.getElementById('sampleBtn'), fitBtn = document.getElementById('fitViewBtn'), resetBtn = document.getElementById('resetViewBtn');
        const playBtn = document.getElementById('playSimBtn'), stepBtn = document.getElementById('stepSimBtn'), resetSim = document.getElementById('resetSimBtn');
        const exportBtn = document.getElementById('exportImgBtn'), viewTabs = document.querySelectorAll('.view-tab');
        const speedSlider = document.getElementById('speedSlider'), lineSlider = document.getElementById('lineWidthSlider');
        const speedVal = document.getElementById('speedValue'), lineVal = document.getElementById('lineWidthValue');

        function loadGCode(content, name, size) {
            document.getElementById('fileName').innerText = name;
            document.getElementById('fileSize').innerText = size<1024?size+' B':(size/1024).toFixed(1)+' KB';
            let lines = content.split('\n');
            document.getElementById('lineCount').innerText = lines.length;
            document.getElementById('unitsInfo').innerText = 'mm';
            viewer.parseGCode(content);
            let previewDiv = document.getElementById('gcodePreview');
            previewDiv.innerHTML = lines.slice(0,70).map(l=>`<div style="font-family:monospace; font-size:0.7rem;">${escapeHtml(l.substring(0,80))}</div>`).join('');
            if(lines.length>70) previewDiv.innerHTML+=`<div style="color:#aaa;">... +${lines.length-70} Zeilen</div>`;
        }
        function escapeHtml(str){ return str.replace(/[&<>]/g, m=> ({'&':'&amp;','<':'&lt;','>':'&gt;'})[m]); }
        function handleFile(file){ const reader=new FileReader(); reader.onload=e=>loadGCode(e.target.result, file.name, file.size); reader.readAsText(file); }
        uploadZone.addEventListener('click',()=>fileInput.click());
        uploadZone.addEventListener('dragover',e=>e.preventDefault());
        uploadZone.addEventListener('drop',e=>{ e.preventDefault(); if(e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
        fileInput.addEventListener('change',e=>{if(e.target.files[0]) handleFile(e.target.files[0]);});
        sampleBtn.addEventListener('click',()=>{ loadGCode(`G90 G21 G17
G0 X0 Y0
G1 Z-1 F200
X15 Y0
G2 X15 Y15 I0 J7.5
G1 X0 Y15
G0 Z5
M30`, 'Beispiel.nc', 180); });
        fitBtn.addEventListener('click',()=>viewer.fitToView());
        resetBtn.addEventListener('click',()=>{ viewer.view2D.zoom=1; viewer.view2D.panX=0; viewer.view2D.panY=0; viewer.view3D.yaw=-30; viewer.view3D.pitch=35; viewer.view3D.distance=180; viewer.fitToView(); });
        playBtn.addEventListener('click',()=>viewer.playSim());
        stepBtn.addEventListener('click',()=>viewer.stepSim());
        resetSim.addEventListener('click',()=>viewer.resetSim());
        exportBtn.addEventListener('click',()=>viewer.exportImage());
        viewTabs.forEach(t=>t.addEventListener('click',()=>viewer.setView(t.dataset.view)));
        speedSlider.addEventListener('input',()=>{ const v=['Sehr langsam','Langsam','Mittel','Schnell']; speedVal.innerText=v[speedSlider.value-1]; if(viewer.isPlaying){ viewer.stopSim(); viewer.playSim(); } });
        lineSlider.addEventListener('input',()=>{ const v=['Dünn','Mittel','Dick']; lineVal.innerText=v[lineSlider.value-1]; viewer.draw(); });
        document.getElementById('gridToggle').addEventListener('change',()=>viewer.draw());
        document.getElementById('rapidToggle').addEventListener('change',()=>viewer.draw());
        document.getElementById('depthToggle').addEventListener('change',()=>viewer.draw());
        viewer.handleResize();
    })();
</script>
</body>
</html>
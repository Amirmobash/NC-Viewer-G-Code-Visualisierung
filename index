                <div class="slider-container"><div class="slider-label"><span>⚡ Animationsgeschw.</span><span id="speed-value">Mittel</span></div><input type="range" min="1" max="4" value="2" id="speed-slider"></div>
                <div style="display: flex; gap: 10px; margin-top: 1rem;">

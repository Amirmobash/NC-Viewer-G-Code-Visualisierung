</header>

<div class="container">
    <div class="main-content">
        <!-- Linke Steuerung -->
        <div class="control-panel">
            <div class="panel-section">
                <h3>📁 Datei laden</h3>
                <div class="file-upload" id="upload-area">
                    <div class="upload-icon">📂</div>
                    <p>NC / G-Code hierher ziehen</p>
                    <p style="font-size:0.75rem; color:gray;">.nc, .gcode, .cnc, .txt</p>
                    <input type="file" id="file-input" accept=".nc,.gcode,.cnc,.txt" style="display:none">

<script>
    (function(){
        // ----- Verbesserter G-Code Viewer mit Theme Orange/Weiß -----
        class GCodeViewer {
            constructor(canvas) {
                this.canvas = canvas;
                this.ctx = canvas.getContext('2d');
                this.segments = [];
                this.bbox = { minX:0, minY:0, minZ:0, maxX:0, maxY:0, maxZ:0 };
                this.view2D = { zoom:1, panX:0, panY:0, offsetX:0, offsetY:0 };
                this.view3D = { yaw:45, pitch:30, distance:150, targetX:0, targetY:0, targetZ:0 };
                this.mode = { absolute: true, units: 'mm' };
                this.currentPosition = { x:0, y:0, z:0 };
                this.playIndex = 0;
                this.isPlaying = false;
                this.playInterval = null;
                this.speedValues = [800, 300, 120, 50];
                this.lineWidthValues = [1, 2.2, 3.5];
                this.activeView = '2d';
                this.setupMouseControls();
                this.setupCanvasResize();
            }

            setupCanvasResize() {
                const container = this.canvas.parentElement;
                const resizeObserver = new ResizeObserver(() => {
                    this.handleResize();
                });
                resizeObserver.observe(container);
                this.handleResize();
            }

            handleResize() {
                const container = this.canvas.parentElement;
                const rect = container.getBoundingClientRect();
                const dpr = window.devicePixelRatio || 1;
                this.canvas.style.width = rect.width + 'px';
                this.canvas.style.height = rect.height + 'px';
                this.canvas.width = Math.max(1, rect.width * dpr);
                this.canvas.height = Math.max(1, rect.height * dpr);
                this.ctx.setTransform(1,0,0,1,0,0);
                this.ctx.scale(dpr, dpr);
                const cssW = this.canvas.width / dpr;
                const cssH = this.canvas.height / dpr;
                if(this.view2D.offsetX === 0) this.view2D.offsetX = cssW/2;
                if(this.view2D.offsetY === 0) this.view2D.offsetY = cssH/2;
                this.draw();
            }

            setupMouseControls() {
                const container = this.canvas.parentElement;
                let isPan2D = false, isRotate3D = false, isPan3D = false, lastX=0, lastY=0;
                container.addEventListener('wheel', (e) => {
                    e.preventDefault();
                    if(this.activeView === '2d') {
                        const factor = e.deltaY > 0 ? 0.9 : 1.1;
                        this.view2D.zoom = Math.min(12, Math.max(0.15, this.view2D.zoom * factor));
                    } else {
                        const factor = e.deltaY > 0 ? 1.08 : 0.92;
                        this.view3D.distance = Math.min(800, Math.max(20, this.view3D.distance * factor));
                    }
                    this.updateUI(); this.draw();
                });
                container.addEventListener('mousedown', (e) => {
                    if(e.button !== 0) return;
                    if(this.activeView === '2d') { isPan2D = true; }
                    else { if(e.shiftKey) isPan3D = true; else isRotate3D = true; }
                    lastX = e.clientX; lastY = e.clientY;
                    container.style.cursor = 'grabbing';
                });
                window.addEventListener('mousemove', (e) => {
                    if(isPan2D) {
                        const dx = e.clientX - lastX, dy = e.clientY - lastY;
                        this.view2D.panX -= dx / this.view2D.zoom;
                        this.view2D.panY -= dy / this.view2D.zoom;
                        lastX = e.clientX; lastY = e.clientY;
                        this.draw();
                    } else if(isRotate3D) {
                        this.view3D.yaw += (e.clientX - lastX) * 0.6;
                        this.view3D.pitch += (e.clientY - lastY) * 0.6;
                        this.view3D.pitch = Math.min(89, Math.max(-89, this.view3D.pitch));
                        lastX = e.clientX; lastY = e.clientY;
                        this.updateUI(); this.draw();
                    } else if(isPan3D) {
                        const speed = this.view3D.distance * 0.002;
                        this.view3D.targetX -= (e.clientX - lastX) * speed;
                        this.view3D.targetY += (e.clientY - lastY) * speed;
                        lastX = e.clientX; lastY = e.clientY;
                        this.draw();
                    }
                });
                window.addEventListener('mouseup', () => { isPan2D=false; isRotate3D=false; isPan3D=false; container.style.cursor='grab'; });
                container.addEventListener('dblclick', () => this.fitToView());
                container.addEventListener('mousemove', (e) => {
                    if(this.activeView === '2d') {
                        const rect = this.canvas.getBoundingClientRect();
                        const mx = e.clientX - rect.left, my = e.clientY - rect.top;
                        const wx = this.screenToWorldX(mx), wy = this.screenToWorldY(my);
                        document.getElementById('coord-panel').innerHTML = `📍 X:${wx.toFixed(2)} Y:${wy.toFixed(2)} Z:0.00`;
                    } else {
                        document.getElementById('coord-panel').innerHTML = `🎮 3D-Modus | Ziel: X:${this.view3D.targetX.toFixed(1)} Y:${this.view3D.targetY.toFixed(1)}`;
                    }
                });
            }

            screenToWorldX(sx) { return (sx - this.view2D.offsetX)/this.view2D.zoom + this.view2D.panX; }
            screenToWorldY(sy) { return (sy - this.view2D.offsetY)/this.view2D.zoom + this.view2D.panY; }
            worldToScreenX(wx) { return (wx - this.view2D.panX)*this.view2D.zoom + this.view2D.offsetX; }
            worldToScreenY(wy) { return (wy - this.view2D.panY)*this.view2D.zoom + this.view2D.offsetY; }

            project3D(x,y,z) {
                let rx = x - this.view3D.targetX, ry = y - this.view3D.targetY, rz = z - this.view3D.targetZ;
                const yawRad = this.view3D.yaw * Math.PI/180, pitchRad = this.view3D.pitch * Math.PI/180;
                const x1 = rx * Math.cos(yawRad) - rz * Math.sin(yawRad);
                const z1 = rx * Math.sin(yawRad) + rz * Math.cos(yawRad);
                const y1 = ry * Math.cos(pitchRad) - z1 * Math.sin(pitchRad);
                const z2 = ry * Math.sin(pitchRad) + z1 * Math.cos(pitchRad);
                const fov = Math.PI/4;
                const scale = Math.min(this.canvas.width/(window.devicePixelRatio||1), this.canvas.height/(window.devicePixelRatio||1))/2;
                const zTrans = z2 - this.view3D.distance;
                const factor = fov / (Math.abs(zTrans) < 0.001 ? 0.001 : zTrans);
                return { x: x1 * factor * scale + this.canvas.width/(window.devicePixelRatio||1)/2, y: y1 * factor * scale + this.canvas.height/(window.devicePixelRatio||1)/2, depth: zTrans };
            }

            parseGCode(gcodeStr) {
                this.segments = []; this.currentPosition = {x:0,y:0,z:0}; this.mode = {absolute:true, units:'mm'};
                const lines = gcodeStr.split(/\r?\n/);
                for(let raw of lines) {
                    let line = raw.split(';')[0].split('(')[0].trim().toUpperCase();
                    if(!line) continue;
                    if(line.includes('G90')) this.mode.absolute = true;
                    if(line.includes('G91')) this.mode.absolute = false;
                    if(line.includes('G20')) this.mode.units = 'inch';
                    if(line.includes('G21')) this.mode.units = 'mm';
                    if(line.match(/G0[0]?/) || line.match(/G0[0]?/)) this.parseMovement(line, true);
                    else if(line.match(/G1[01]?/)) this.parseMovement(line, false);
                    else if(line.match(/G2|G3|G02|G03/)) this.parseArc(line, false);
                }
                this.calcBBox();
                this.fitToView();
                this.stopPlayback();
                this.playIndex = 0;
                this.updateUI();
                this.draw();
            }

            parseMovement(line, rapid) {
                let x = this.currentPosition.x, y = this.currentPosition.y, z = this.currentPosition.z;
                let changed = false;
                const getVal = (c) => { let m = line.match(new RegExp(c+'([-+]?\\d*\\.?\\d+)')); return m ? parseFloat(m[1]) : null; };
                let nx = getVal('X'); if(nx !== null) { x = this.mode.absolute ? nx : this.currentPosition.x + nx; changed=true; }
                let ny = getVal('Y'); if(ny !== null) { y = this.mode.absolute ? ny : this.currentPosition.y + ny; changed=true; }
                let nz = getVal('Z'); if(nz !== null) { z = this.mode.absolute ? nz : this.currentPosition.z + nz; changed=true; }
                if(this.mode.units === 'inch') { x*=25.4; y*=25.4; z*=25.4; }
                if(changed && (x!==this.currentPosition.x || y!==this.currentPosition.y || z!==this.currentPosition.z)) {
                    this.segments.push({ x1:this.currentPosition.x, y1:this.currentPosition.y, z1:this.currentPosition.z, x2:x, y2:y, z2:z, rapid, arc:false });
                    this.currentPosition = {x,y,z};
                }
            }

            parseArc(line, rapid) {
                let x = this.currentPosition.x, y = this.currentPosition.y;
                let nx=null, ny=null, i=0, j=0;
                const xm = line.match(/X([-+]?\d*\.?\d+)/), ym = line.match(/Y([-+]?\d*\.?\d+)/), im = line.match(/I([-+]?\d*\.?\d+)/), jm = line.match(/J([-+]?\d*\.?\d+)/);
                if(!xm || !ym || !im || !jm) return;
                nx = parseFloat(xm[1]); ny = parseFloat(ym[1]); i = parseFloat(im[1]); j = parseFloat(jm[1]);
                if(!this.mode.absolute) { nx += this.currentPosition.x; ny += this.currentPosition.y; }
                const centerX = this.currentPosition.x + i, centerY = this.currentPosition.y + j;
                const radius = Math.hypot(this.currentPosition.x - centerX, this.currentPosition.y - centerY);
                let startAng = Math.atan2(this.currentPosition.y - centerY, this.currentPosition.x - centerX);
                let endAng = Math.atan2(ny - centerY, nx - centerX);
                const clockwise = line.includes('G2') || line.includes('G02');
                let angleDiff = endAng - startAng;
                if(clockwise) { while(angleDiff > 0) angleDiff -= 2*Math.PI; while(angleDiff < -2*Math.PI) angleDiff += 2*Math.PI; }
                else { while(angleDiff < 0) angleDiff += 2*Math.PI; while(angleDiff > 2*Math.PI) angleDiff -= 2*Math.PI; }
                const steps = Math.max(12, Math.floor(Math.abs(angleDiff) * 12 / (2*Math.PI)));
                let lastX = this.currentPosition.x, lastY = this.currentPosition.y;
                for(let s=1; s<=steps; s++) {
                    let ang = startAng + angleDiff * s/steps;
                    let px = centerX + radius * Math.cos(ang), py = centerY + radius * Math.sin(ang);
                    this.segments.push({ x1:lastX, y1:lastY, z1:this.currentPosition.z, x2:px, y2:py, z2:this.currentPosition.z, rapid, arc:true });
                    lastX = px; lastY = py;
                }
                this.currentPosition = { x:nx, y:ny, z:this.currentPosition.z };
            }

            calcBBox() {
                if(!this.segments.length) { this.bbox = {minX:-20,minY:-20,minZ:-20,maxX:20,maxY:20,maxZ:20}; return; }
                let minX=Infinity,minY=Infinity,minZ=Infinity,maxX=-Infinity,maxY=-Infinity,maxZ=-Infinity;
                for(let s of this.segments) {
                    minX = Math.min(minX,s.x1,s.x2); maxX = Math.max(maxX,s.x1,s.x2);
                    minY = Math.min(minY,s.y1,s.y2); maxY = Math.max(maxY,s.y1,s.y2);
                    minZ = Math.min(minZ,s.z1,s.z2); maxZ = Math.max(maxZ,s.z1,s.z2);
                }
                let pad = Math.max((maxX-minX)*0.08, (maxY-minY)*0.08, 1);
                this.bbox = { minX:minX-pad, maxX:maxX+pad, minY:minY-pad, maxY:maxY+pad, minZ:minZ-pad, maxZ:maxZ+pad };
                const rangeX = document.getElementById('range-x');
                const rangeYZ = document.getElementById('range-yz');
                if(rangeX) rangeX.innerText = `${minX.toFixed(1)}..${maxX.toFixed(1)}`;
                if(rangeYZ) rangeYZ.innerText = `Y:${minY.toFixed(1)}..${maxY.toFixed(1)} Z:${minZ.toFixed(1)}..${maxZ.toFixed(1)}`;
            }

            fitToView() {
                if(this.activeView === '2d') {
                    const w = this.canvas.width/(window.devicePixelRatio||1), h = this.canvas.height/(window.devicePixelRatio||1);
                    const ww = this.bbox.maxX - this.bbox.minX, hh = this.bbox.maxY - this.bbox.minY;
                    if(ww>0 && hh>0) {
                        this.view2D.zoom = Math.min(w/ww, h/hh) * 0.9;
                        this.view2D.panX = (this.bbox.minX+this.bbox.maxX)/2;
                        this.view2D.panY = (this.bbox.minY+this.bbox.maxY)/2;
                        this.view2D.offsetX = w/2; this.view2D.offsetY = h/2;
                    }
                } else {
                    this.view3D.targetX = (this.bbox.minX+this.bbox.maxX)/2;
                    this.view3D.targetY = (this.bbox.minY+this.bbox.maxY)/2;
                    this.view3D.targetZ = (this.bbox.minZ+this.bbox.maxZ)/2;
                    let maxDim = Math.max(this.bbox.maxX-this.bbox.minX, this.bbox.maxY-this.bbox.minY, this.bbox.maxZ-this.bbox.minZ);
                    this.view3D.distance = maxDim * 1.3;
                    this.view3D.yaw = 45; this.view3D.pitch = 30;
                }
                this.updateUI(); this.draw();
            }

            draw() {
                const w = this.canvas.width/(window.devicePixelRatio||1), h = this.canvas.height/(window.devicePixelRatio||1);
                this.ctx.clearRect(0,0,w,h);
                this.ctx.fillStyle = '#ffffff'; this.ctx.fillRect(0,0,w,h);
                if(this.activeView === '2d') this.draw2D(w,h);
                else this.draw3D(w,h);
            }

            draw2D(w,h) {
                if(document.getElementById('grid-toggle').checked) this.drawGrid2D(w,h);
                const rapidVis = document.getElementById('rapid-toggle').checked;
                const lwIdx = parseInt(document.getElementById('line-width-slider').value)-1;
                const lw = this.lineWidthValues[lwIdx];
                for(let i=0; i<this.segments.length; i++) {
                    if(this.isPlaying && i>=this.playIndex) break;
                    const s = this.segments[i];
                    const x1=this.worldToScreenX(s.x1), y1=this.worldToScreenY(s.y1), x2=this.worldToScreenX(s.x2), y2=this.worldToScreenY(s.y2);
                    this.ctx.beginPath();
                    this.ctx.moveTo(x1,y1); this.ctx.lineTo(x2,y2);
                    if(s.rapid && rapidVis) { this.ctx.strokeStyle = '#f97316'; this.ctx.setLineDash([6,6]); }
                    else { this.ctx.strokeStyle = '#ea580c'; this.ctx.setLineDash([]); }
                    this.ctx.lineWidth = lw; this.ctx.stroke();
                }
                this.ctx.setLineDash([]);
                if(this.isPlaying && this.playIndex>0) {
                    let last = this.segments[this.playIndex-1];
                    let cx=this.worldToScreenX(last.x2), cy=this.worldToScreenY(last.y2);
                    this.ctx.fillStyle = '#f97316'; this.ctx.beginPath(); this.ctx.arc(cx,cy,6,0,2*Math.PI); this.ctx.fill();
                }
            }

            drawGrid2D(w,h) {
                const left=this.screenToWorldX(0), right=this.screenToWorldX(w), top=this.screenToWorldY(0), bottom=this.screenToWorldY(h);
                let step = 10; if(this.view2D.zoom>1.2) step=5; if(this.view2D.zoom>2.5) step=2;
                this.ctx.strokeStyle = '#e2e8f0'; this.ctx.lineWidth = 0.8;
                for(let x=Math.floor(left/step)*step; x<=right; x+=step) { let sx=this.worldToScreenX(x); if(sx>0 && sx<w){ this.ctx.beginPath(); this.ctx.moveTo(sx,0); this.ctx.lineTo(sx,h); this.ctx.stroke(); } }
                for(let y=Math.floor(top/step)*step; y<=bottom; y+=step) { let sy=this.worldToScreenY(y); if(sy>0 && sy<h){ this.ctx.beginPath(); this.ctx.moveTo(0,sy); this.ctx.lineTo(w,sy); this.ctx.stroke(); } }
                this.ctx.beginPath(); let ax=this.worldToScreenX(0); if(ax>0&&ax<w){ this.ctx.moveTo(ax,0); this.ctx.lineTo(ax,h); } let ay=this.worldToScreenY(0); if(ay>0&&ay<h){ this.ctx.moveTo(0,ay); this.ctx.lineTo(w,ay); } this.ctx.strokeStyle='#f97316'; this.ctx.lineWidth=1.5; this.ctx.stroke();
            }

            draw3D(w,h) {
                if(document.getElementById('grid-toggle').checked) this.drawGrid3D();
                const rapidVis = document.getElementById('rapid-toggle').checked, depthEff = document.getElementById('depth-toggle').checked;
                const lwIdx = parseInt(document.getElementById('line-width-slider').value)-1, lw = this.lineWidthValues[lwIdx];
                let proj = [];
                for(let i=0; i<this.segments.length; i++) {
                    if(this.isPlaying && i>=this.playIndex) break;
                    let s=this.segments[i];
                    let p1=this.project3D(s.x1,s.y1,s.z1), p2=this.project3D(s.x2,s.y2,s.z2);
                    proj.push({p1,p2,rapid:s.rapid,depth:(p1.depth+p2.depth)/2});
                }
                proj.sort((a,b)=>b.depth-a.depth);
                for(let p of proj) {
                    this.ctx.beginPath(); this.ctx.moveTo(p.p1.x,p.p1.y); this.ctx.lineTo(p.p2.x,p.p2.y);
                    if(p.rapid && rapidVis) { this.ctx.strokeStyle = '#f97316'; this.ctx.setLineDash([5,5]); }
                    else { this.ctx.strokeStyle = '#ea580c'; this.ctx.setLineDash([]); }
                    if(depthEff) this.ctx.globalAlpha = Math.min(1, Math.max(0.3, 1 - (p.depth+this.view3D.distance)/(this.view3D.distance*1.8)));
                    else this.ctx.globalAlpha = 1;
                    this.ctx.lineWidth = lw; this.ctx.stroke();
                }
                this.ctx.globalAlpha=1; this.ctx.setLineDash([]);
            }

            drawGrid3D() {
                let size = Math.max(50, (this.bbox.maxX-this.bbox.minX)/1.5);
                let step = 10;
                this.ctx.strokeStyle='#d6d3d1'; this.ctx.lineWidth=0.7;
                for(let x=-size; x<=size; x+=step) { let p1=this.project3D(x,-size,0), p2=this.project3D(x,size,0); this.ctx.beginPath(); this.ctx.moveTo(p1.x,p1.y); this.ctx.lineTo(p2.x,p2.y); this.ctx.stroke(); }
                for(let y=-size; y<=size; y+=step) { let p1=this.project3D(-size,y,0), p2=this.project3D(size,y,0); this.ctx.beginPath(); this.ctx.moveTo(p1.x,p1.y); this.ctx.lineTo(p2.x,p2.y); this.ctx.stroke(); }
            }

            play() { if(!this.segments.length) return; if(this.isPlaying) { this.stopPlayback(); return; } this.isPlaying=true; this.playIndex=0; const speedIdx=parseInt(document.getElementById('speed-slider').value)-1; const delay=this.speedValues[speedIdx]; this.playInterval=setInterval(()=>{ if(this.playIndex<this.segments.length){ this.playIndex++; this.draw(); if(this.playIndex>=this.segments.length) this.stopPlayback(); } else this.stopPlayback(); }, delay); document.getElementById('play-btn').innerHTML='⏹️ Simulation stoppen'; }
            stopPlayback() { if(this.playInterval){ clearInterval(this.playInterval); this.playInterval=null; } this.isPlaying=false; document.getElementById('play-btn').innerHTML='▶️ Simulation starten'; this.draw(); }
            step() { if(!this.isPlaying && this.playIndex>=this.segments.length) this.playIndex=0; if(this.playIndex<this.segments.length){ this.playIndex++; this.draw(); if(this.playIndex>=this.segments.length) this.stopPlayback(); } else this.stopPlayback(); }
            resetSim() { this.stopPlayback(); this.playIndex=0; this.draw(); }
            updateUI() { document.getElementById('zoom-level').innerText=Math.round((this.activeView==='2d'?this.view2D.zoom:this.view3D.distance/100)*100)+'%'; document.getElementById('view-type').innerText=this.activeView; document.getElementById('camera-info').style.display=this.activeView==='3d'?'block':'none'; if(this.activeView==='3d'){ document.getElementById('camera-angles').innerText=`${Math.round(this.view3D.yaw)}°/${Math.round(this.view3D.pitch)}°`; document.getElementById('camera-distance').innerText=Math.round(this.view3D.distance); } }
            setView(v) { this.activeView=v; document.querySelectorAll('.view-tab').forEach(t=>t.classList.toggle('active',t.dataset.view===v)); document.getElementById('view-title').innerText=v==='2d'?'2D-Visualisierung (XY-Ebene)':'3D-Ansicht (Orbit)'; this.fitToView(); this.updateUI(); this.draw(); }
            exportImage() { const link=document.createElement('a'); link.download='nc-viewer.png'; link.href=this.canvas.toDataURL(); link.click(); }
        }

        // DOM Bindung
        const canvas = document.getElementById('viewer-canvas');
        const viewer = new GCodeViewer(canvas);
        const uploadArea = document.getElementById('upload-area'), fileInput = document.getElementById('file-input');
        const loadSample = document.getElementById('load-sample'), fitBtn = document.getElementById('fit-view'), resetBtn = document.getElementById('reset-view');
        const playBtn = document.getElementById('play-btn'), stepBtn = document.getElementById('step-btn'), resetSimBtn = document.getElementById('reset-sim-btn');
        const exportBtn = document.getElementById('export-btn'), viewTabs = document.querySelectorAll('.view-tab');
        const speedSlider = document.getElementById('speed-slider'), lineWidthSlider = document.getElementById('line-width-slider');
        const gridToggle = document.getElementById('grid-toggle'), rapidToggle = document.getElementById('rapid-toggle'), depthToggle = document.getElementById('depth-toggle');
        const speedVal = document.getElementById('speed-value'), lineWidthVal = document.getElementById('line-width-value');

        function handleFileContent(content, name, size) {
            document.getElementById('filename').innerText = name;
            document.getElementById('filesize').innerText = size<1024?size+' B':(size/1024).toFixed(1)+' KB';
            const lines = content.split('\n');
            document.getElementById('line-count').innerText = lines.length;
            viewer.parseGCode(content);
            const previewDiv = document.getElementById('gcode-preview');
            previewDiv.innerHTML = lines.slice(0,80).map(l=>`<div style="font-family:monospace;">${escapeHtml(l.substring(0,80))}</div>`).join('');
            if(lines.length>80) previewDiv.innerHTML+=`<div style="color:#aaa;">... +${lines.length-80} Zeilen</div>`;
        }
        function escapeHtml(str){ return str.replace(/[&<>]/g, function(m){if(m==='&') return '&amp;'; if(m==='<') return '&lt;'; if(m==='>') return '&gt;'; return m;});}
        function handleFile(file){ const reader=new FileReader(); reader.onload=e=>handleFileContent(e.target.result, file.name, file.size); reader.readAsText(file); }
        uploadArea.addEventListener('click',()=>fileInput.click()); uploadArea.addEventListener('dragover',e=>e.preventDefault()); uploadArea.addEventListener('drop',e=>{ e.preventDefault(); if(e.dataTransfer.files[0]) handleFile(e.dataTransfer.files[0]); });
        fileInput.addEventListener('change',e=>{if(e.target.files[0]) handleFile(e.target.files[0]);});
        loadSample.addEventListener('click',()=>{ handleFileContent(`% (SAMPLE: Quadrat mit Bohrung)
G90 G21 G17
G0 X0 Y0
G1 Z-1 F100
X10 Y0
G2 X10 Y10 I0 J5
G1 X0 Y10
G0 Z5
M30`, 'beispiel.nc', 280); });
        fitBtn.addEventListener('click',()=>viewer.fitToView());
        resetBtn.addEventListener('click',()=>{ viewer.view2D.zoom=1; viewer.view2D.panX=0; viewer.view2D.panY=0; viewer.view3D.yaw=45; viewer.view3D.pitch=30; viewer.view3D.distance=150; viewer.fitToView(); });
        playBtn.addEventListener('click',()=>viewer.play());
        stepBtn.addEventListener('click',()=>viewer.step());
        resetSimBtn.addEventListener('click',()=>viewer.resetSim());
        exportBtn.addEventListener('click',()=>viewer.exportImage());
        viewTabs.forEach(t=>t.addEventListener('click',()=>viewer.setView(t.dataset.view)));
        speedSlider.addEventListener('input',()=>{ const vals=['Sehr langsam','Langsam','Mittel','Schnell']; speedVal.innerText=vals[speedSlider.value-1]; if(viewer.isPlaying){ viewer.stopPlayback(); viewer.play(); } });
        lineWidthSlider.addEventListener('input',()=>{ const vals=['Dünn','Mittel','Dick']; lineWidthVal.innerText=vals[lineWidthSlider.value-1]; viewer.draw(); });
        gridToggle.addEventListener('change',()=>viewer.draw()); rapidToggle.addEventListener('change',()=>viewer.draw()); depthToggle.addEventListener('change',()=>viewer.draw());
        viewer.handleResize();
    })();
</script>
</body>
</html>